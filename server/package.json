{
  "name": "cf-dns-manager-server",
  "version": "1.0.0",
  "description": "Cloudflare DNS Manager - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma db push --skip-generate && tsx watch src/index.ts",
    "build": "tsc",
    "start": "prisma db push && node dist/index.js",
    "cert:renew:drill": "tsx src/scripts/certificate-renewal-drill.ts",
    "cert:deploy:migrate:npm-type": "tsx src/scripts/migrate-npm-deploy-target-type.ts",
    "cert:vendor:migrate:foundation": "tsx src/scripts/migrate-vendor-certificate-foundation.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "cloudflare",
    "dns",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1017.0",
    "@aws-sdk/client-cloudfront": "^3.1017.0",
    "@aws-sdk/client-sts": "^3.1017.0",
    "@peculiar/x509": "^1.14.3",
    "@prisma/client": "^5.22.0",
    "@types/node-forge": "^1.3.14",
    "@types/ssh2": "^1.15.5",
    "acme-client": "^5.4.0",
    "basic-ftp": "^5.2.0",
    "bcrypt": "^5.1.1",
    "cloudflare": "^3.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "node-cache": "^5.1.2",
    "node-forge": "^1.4.0",
    "nodemailer": "^6.10.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^12.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
