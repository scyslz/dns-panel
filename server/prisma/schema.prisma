generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                              Int      @id @default(autoincrement())
  username                        String   @unique
  email                           String?  @unique
  password                        String
  cfApiToken                      String?
  cfAccountId                     String?
  twoFactorSecret                 String?
  twoFactorEnabled                Boolean  @default(false)
  domainExpiryDisplayMode         String   @default("date")
  domainExpiryThresholdDays       Int      @default(7)
  showNonAuthoritativeDomains     Boolean  @default(false)
  domainExpiryNotifyEnabled       Boolean  @default(false)
  domainExpiryNotifyWebhookUrl    String?
  domainExpiryNotifyEmailEnabled  Boolean  @default(false)
  domainExpiryNotifyEmailTo       String?
  smtpHost                        String?
  smtpPort                        Int?
  smtpSecure                      Boolean?
  smtpUser                        String?
  smtpPass                        String?
  smtpFrom                        String?
  certificateSettingsJson         String?
  certificateSettingsSecrets      String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  logs                            Log[]
  dnsCredentials                  DnsCredential[]
  certificateCredentials          CertificateCredential[]
  certificateOrders               CertificateOrder[]
  certificateDeployTargets        CertificateDeployTarget[]
  vendorCertificateOrders         VendorCertificateOrder[]
  certificateAliases              CertificateCnameAlias[]
  cfCredentials                   CfCredential[] @relation("CfCredentials")
  domainExpiryNotifications       DomainExpiryNotification[]
  domainExpiryOverrides           DomainExpiryOverride[]

  @@map("users")
}

model DnsCredential {
  id                              Int      @id @default(autoincrement())
  userId                          Int
  user                            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                            String
  provider                        String
  secrets                         String
  accountId                       String?
  isDefault                       Boolean  @default(false)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
  certificateOrders               CertificateOrder[]
  legacyVendorCertificateOrders   VendorCertificateOrder[] @relation("LegacyVendorDnsCredential")
  vendorCredentialOrders          VendorCertificateOrder[] @relation("VendorCredentialOrders")
  validationVendorCertificateOrders VendorCertificateOrder[] @relation("ValidationDnsCredentialOrders")
  certificateAliases              CertificateCnameAlias[]

  @@index([userId])
  @@index([provider])
  @@map("dns_credentials")
}

model CertificateCredential {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  provider      String
  email         String
  directoryUrl  String?
  eabKid        String?
  eabHmacKey    String?
  accountKeyPem String
  accountUrl    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        CertificateOrder[]

  @@index([userId])
  @@index([provider])
  @@map("certificate_credentials")
}

model CertificateOrder {
  id                      Int                   @id @default(autoincrement())
  userId                  Int
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificateCredentialId Int
  certificateCredential   CertificateCredential @relation(fields: [certificateCredentialId], references: [id], onDelete: Restrict)
  dnsCredentialId         Int
  dnsCredential           DnsCredential         @relation(fields: [dnsCredentialId], references: [id], onDelete: Restrict)
  primaryDomain           String
  domainsJson             String
  status                  String
  challengeRecordsJson    String?
  privateKeyPem           String?
  certificatePem          String?
  fullchainPem            String?
  issuedAt                DateTime?
  expiresAt               DateTime?
  autoRenew               Boolean               @default(true)
  retryCount              Int                   @default(0)
  nextRetryAt             DateTime?
  lastError               String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  deployJobs              CertificateDeployJob[] @relation("AcmeDeployJobs")

  @@index([userId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([expiresAt])
  @@map("certificate_orders")
}

model CertificateDeployTarget {
  id         Int                    @id @default(autoincrement())
  userId     Int
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  type       String
  configJson String
  isDefault  Boolean                @default(false)
  enabled    Boolean                @default(true)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  jobs       CertificateDeployJob[]

  @@index([userId])
  @@index([type])
  @@index([enabled])
  @@map("certificate_deploy_targets")
}

model CertificateDeployJob {
  id                        Int                     @id @default(autoincrement())
  certificateOrderId        Int?
  certificateOrder          CertificateOrder?       @relation("AcmeDeployJobs", fields: [certificateOrderId], references: [id], onDelete: Cascade)
  vendorCertificateOrderId  Int?
  vendorCertificateOrder    VendorCertificateOrder? @relation("VendorDeployJobs", fields: [vendorCertificateOrderId], references: [id], onDelete: Cascade)
  certificateDeployTargetId Int
  certificateDeployTarget   CertificateDeployTarget @relation(fields: [certificateDeployTargetId], references: [id], onDelete: Restrict)
  bindingJson               String?
  enabled                   Boolean                 @default(true)
  triggerOnIssue            Boolean                 @default(true)
  triggerOnRenew            Boolean                 @default(true)
  lastStatus                String?
  lastError                 String?
  lastTriggeredAt           DateTime?
  lastSucceededAt           DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  runs                      CertificateDeployRun[]

  @@index([certificateOrderId])
  @@index([vendorCertificateOrderId])
  @@index([certificateDeployTargetId])
  @@index([enabled])
  @@map("certificate_deploy_jobs")
}

model CertificateDeployRun {
  id         Int                  @id @default(autoincrement())
  jobId       Int
  job         CertificateDeployJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  event       String
  triggerMode String
  status      String
  scheduledAt DateTime
  startedAt   DateTime?
  finishedAt  DateTime?
  lastError   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([jobId])
  @@index([status, scheduledAt])
  @@map("certificate_deploy_runs")
}

model VendorCertificateOrder {
  id                        Int                   @id @default(autoincrement())
  userId                    Int
  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider                  String
  dnsCredentialId           Int?
  legacyDnsCredential       DnsCredential?        @relation("LegacyVendorDnsCredential", fields: [dnsCredentialId], references: [id], onDelete: Restrict)
  vendorCredentialId        Int?
  vendorCredential          DnsCredential?        @relation("VendorCredentialOrders", fields: [vendorCredentialId], references: [id], onDelete: Restrict)
  validationDnsCredentialId Int?
  validationDnsCredential   DnsCredential?        @relation("ValidationDnsCredentialOrders", fields: [validationDnsCredentialId], references: [id], onDelete: Restrict)
  primaryDomain             String
  domainsJson               String
  contactProfileJson        String?
  status                    String
  providerOrderId           String?
  providerCertificateId     String?
  validationPayloadJson     String?
  certificatePem            String?
  fullchainPem              String?
  privateKeyPem             String?
  issuedAt                  DateTime?
  expiresAt                 DateTime?
  lastSyncAt                DateTime?
  lastError                 String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  deployJobs                CertificateDeployJob[] @relation("VendorDeployJobs")

  @@index([userId])
  @@index([provider])
  @@index([status])
  @@index([lastSyncAt])
  @@index([expiresAt])
  @@index([vendorCredentialId])
  @@index([validationDnsCredentialId])
  @@map("vendor_certificate_orders")
}

model CertificateCnameAlias {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain        String
  dnsCredentialId Int
  dnsCredential DnsCredential @relation(fields: [dnsCredentialId], references: [id], onDelete: Restrict)
  zoneName      String
  rr            String
  targetFqdn    String
  status        String
  lastCheckedAt DateTime?
  lastError     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, domain])
  @@unique([dnsCredentialId, rr])
  @@index([userId])
  @@index([status])
  @@map("certificate_cname_aliases")
}

model CfCredential {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation("CfCredentials", fields: [userId], references: [id], onDelete: Cascade)
  name        String
  apiToken    String
  accountId   String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("cf_credentials")
}

model Log {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp     DateTime @default(now())
  action        String
  resourceType  String
  domain        String?
  recordName    String?
  recordType    String?
  oldValue      String?
  newValue      String?
  status        String
  errorMessage  String?
  ipAddress     String?

  @@index([userId])
  @@index([timestamp])
  @@index([action])
  @@index([resourceType])
  @@index([status])
  @@map("logs")
}

model Cache {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("cache")
}

model DomainExpiryNotification {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain         String
  expiresAt      DateTime
  thresholdDays  Int
  channel        String
  status         String
  payload        String?
  errorMessage   String?
  createdAt      DateTime @default(now())
  lastNotifiedAt DateTime?

  @@unique([userId, domain, expiresAt, thresholdDays, channel])
  @@index([userId])
  @@index([domain])
  @@index([createdAt])
  @@map("domain_expiry_notifications")
}

model DomainExpiryOverride {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, domain])
  @@index([userId])
  @@map("domain_expiry_overrides")
}
